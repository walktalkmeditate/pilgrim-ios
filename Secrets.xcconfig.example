// Copy this file to Secrets.xcconfig and fill in your tokens.
// Secrets.xcconfig is gitignored and will not be committed.

// Mapbox public access token (pk.*) — create at https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN = pk.your_token_here

// WeatherKit REST API fallback — create a key at https://developer.apple.com/account/resources/authkeys
// Only needed if native WeatherKit fails (e.g., Xcode beta JWT bug)
WEATHERKIT_KEY_ID = your_key_id
WEATHERKIT_TEAM_ID = your_team_id
WEATHERKIT_PRIVATE_KEY = base64_encoded_p8_key

// GitHub PAT for podcast submissions (repo scope, pilgrim-worker Issues)
GITHUB_PODCAST_PAT = ghp_your_token_here
