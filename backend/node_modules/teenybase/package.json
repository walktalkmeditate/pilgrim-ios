{
    "name": "teenybase",
    "version": "0.0.10",
    "type": "module",
    "bin": {
        "teeny": "bin/teeny.js"
    },
    "scripts": {
        "build": "npm run build-ts && npm run ts-node && npm run js-node",
        "test": "npm run check && npm run vitest && npm run test-check && npm run vitest-worker",
        "watch": "concurrently -n \"r,ts,js\" \"npm run build-ts -- -w --preserveWatchOutput\" \"npm run ts-node -- -w --preserveWatchOutput\" \"npm run js-node -- --watch\"",
        "run-pack": "npm pack",

        "prepare": "npm run build",
        "prepublishOnly": "npm run test",
        "vitest": "vitest run --exclude test/worker",
        "vitest-worker": "vitest run -r test/worker",
        "check": "tsc -p tsconfig.json --pretty --noEmit",
        "build-ts": "tsc -p tsconfig.json --pretty",
        "ts-node": "tsc -p src/node/tsconfig.json --pretty",
        "js-node": "esbuild src/node/cli.ts --bundle --outfile=dist/node/cli.js --platform=node --format=esm --packages=external --sourcemap",
        "test-check": "tsc -p test/tsconfig.json --pretty --noEmit",
        "build-runtime-esbuild-temp": "esbuild src/worker/index.ts --bundle --outfile=dist/worker/index.js --format=esm --sourcemap",
        "run-publish": "git diff --exit-code --name-only origin/master * && npm publish && git tag v$npm_package_version && git push --tags"
    },
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        },
        "./worker": {
            "import": {
                "types": "./dist/worker/index.d.ts",
                "default": "./dist/worker/index.js"
            }
        },
        "./node/*": {
            "import": {
                "types": "./dist/node/*.d.ts",
                "default": "./dist/node/*.js"
            }
        },
        "./scaffolds/*": {
            "import": {
                "types": "./dist/scaffolds/*.d.ts",
                "default": "./dist/scaffolds/*.js"
            }
        },
        "./package.json": "./package.json"
    },
    "dependencies": {
        "@iarna/toml": "^2.2.5",
        "hono": "4.6.12",
        "wrangler": "^3.91.0",
        "jsonc-parser": "^3.3.1",
        "dotenv": "^16.4.5",
        "cac": "^6.7.14",
        "prompts": "^2.4.2",
        "@types/prompts": "^2.4.9",
        "@tsndr/cloudflare-worker-jwt": "^2.5.3",
        "jsep": "^1.3.9",
        "@hono/swagger-ui": "^0.4.1",
        "@hono/zod-openapi": "^0.15.3",
        "@hono/zod-validator": "^0.2.2",
        "@cloudflare/workers-types": "^4.20240821.1",
        "picocolors": "^1.1.1"
    },
    "peerDependencies": {
        "@cloudflare/workers-types": "^4.20240821.1",
        "hono": "^4.6.5",
        "wrangler": "^3.91.0"
    },
    "files": [
        "bin",
        "dist",
        "README.md",
        "LICENSE",
        "package.json",
        "tsconfig.json"
    ],
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "^0.5.34",
        "@types/node": "^22.5.0",
        "typescript": "^5.6.3",
        "vite": "^5.4.11",
        "vitest": "2.0.5",
        "concurrently": "^9.1.0"
    },
    "repository": {
        "type": "git",
        "url": "git://github.com/repalash/teenybase"
    },
    "author": "repalash <palash@shaders.app>",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/repalash/teenybase/issues"
    },
    "engines": {
        "node": ">=18.14.1"
    },
    "homepage": "https://teenybase.com"
}
