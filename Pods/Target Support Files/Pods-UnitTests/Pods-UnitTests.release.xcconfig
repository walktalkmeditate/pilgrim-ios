CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Cache" "${PODS_CONFIGURATION_BUILD_DIR}/CombineExt" "${PODS_CONFIGURATION_BUILD_DIR}/CoreGPX" "${PODS_CONFIGURATION_BUILD_DIR}/CoreStore" "${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Cache/Cache.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CombineExt/CombineExt.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CoreGPX/CoreGPX.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CoreStore/CoreStore.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation/ZIPFoundation.framework/Headers"
OTHER_LDFLAGS = $(inherited) -framework "Cache" -framework "Combine" -framework "CombineExt" -framework "CoreData" -framework "CoreGPX" -framework "CoreStore" -framework "Foundation" -framework "ZIPFoundation"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
